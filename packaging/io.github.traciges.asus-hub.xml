<component type="desktop-application">
  <id>io.github.traciges.asus-hub</id>
  <name>Asus Hub</name>
  <summary>Unofficial Control Center for Asus Laptops</summary>

  <metadata_license>FSFAP</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <developer id="Traciges">
    <name>Guido Philipp</name>
  </developer>

  <description>
    <p>
      Asus Hub is a lightweight, native Linux control center for Asus laptops (like Zenbook, Vivobook, and ROG).
      It allows you to tweak deep hardware settings that are usually only available on Windows.
    </p>
    <p>
      This is a community package and is not officially supported by ASUS.
    </p>
    <ul>
      <li
      >Battery Care: Set charging limits to 80% to prolong battery lifespan.</li>
      <li
      >Fan Profiles: Switch between Whisper, Balanced, and Performance modes.</li>
      <li>OLED Care: Manage pixel refresh and panel dimming.</li>
      <li>Keyboard Backlight: Configure sleep timeouts and auto-brightness.</li>
    </ul>
  </description>

